<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#2D2D2D" />
        </shape>
    </item>
    <!-- Progress -->
    <item>
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="8dp" />
                <gradient
                    android:startColor="#3e3e5e"
                    android:endColor="#FFFFFF"
                    android:angle="0" />
            </shape>
        </clip>
    </item>
</layer-list>
