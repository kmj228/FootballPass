<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/main_gradient2">

    <TextView
        android:id="@+id/postTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/postAuther"
            android:layout_marginStart="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginEnd="24dp"/>

        <TextView
            android:id="@+id/postDate"
            android:layout_marginStart="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/rounded_background">


                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/post_likeBtn"
                    android:text="좋아요 0개" />



                <!-- 텍스트 뷰 -->
                <TextView
                    android:id="@+id/textView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="텍스트가 여기에 표시됩니다."
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center_vertical"
                    android:layout_margin="10dp" />

                <!-- 이미지 뷰 -->
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:scaleType="fitCenter"
                    android:layout_margin="10dp" />
            </LinearLayout>

            <Button
                android:layout_marginTop="8dp"
                android:id="@+id/post_deleteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="게시글 삭제"
                android:backgroundTint="#464964"
                android:textColor="#FFFFFF"
                android:layout_gravity="end"/>
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/post_commentEdit"
                android:hint="여기에 댓글입력"
                android:layout_marginTop="30dp"/>

            <Button
                android:layout_marginTop="8dp"
                android:id="@+id/post_commentButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="댓글 등록"
                android:backgroundTint="#464964"
                android:textColor="#FFFFFF"
                android:layout_gravity="end"/>
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/post_swipeRefreshLayout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ListView
                    android:id="@+id/post_commentList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="16dp" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
