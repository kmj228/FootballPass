<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/main_gradient2"
    android:gravity="center">

    <!-- 설정 창에 들어갈 UI 요소들 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="게시판 삭제하기"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/deleteBoardWindow_EditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="30dp"
        android:padding="16dp"
        android:background="@drawable/rounded_background"
        android:textColor="#C4C4C4"
        android:textColorHint="#808080"
        android:hint="삭제할 게시판 이름" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="20dp">

        <Button
            android:id="@+id/deleteBoardWindow_deleteButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#464964"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="20dp"
            android:text="삭제" />

        <Button
            android:id="@+id/deleteBoardWindow_cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#464964"
            android:textColor="#FFFFFF"
            android:text="취소" />
    </LinearLayout>

</LinearLayout>
