<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient2"
    android:orientation="vertical">

    <WebView
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:id="@+id/webView"/>

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="30dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:text="경기 정보"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:gravity="center_horizontal"
            android:id="@+id/cameraIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/photo_camera" />
    </LinearLayout>

    <!-- Game Information Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:weightSum="4"
        android:gravity="center" >

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="100dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/homeTeamImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@mipmap/ic_launcher" />

        </LinearLayout>

        <TextView
            android:id="@+id/homeScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:textColor="#FFFFFF"
            android:text="0"
            android:textSize="40sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/playDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:text="2024년 2월 2일"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/matchTime"
                android:textColor="#FFFFFF"
                android:text="16:00"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/playPlace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="수원월드컵경기장"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text = "관중수: 12,329"
                android:textColor="#FFFFFF"
                android:id="@+id/audience"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/awayScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="40sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="100dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/awayTeamImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@mipmap/ic_launcher" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="득점자"
            android:textColor="#FFFFFF"
            android:id="@+id/homeScorer"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="득점자"
            android:textColor="#FFFFFF"
            android:id="@+id/awayScorer"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_gravity="center" />
    </LinearLayout>


    <!-- Lineup Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:background="#222232"
            app:tabRippleColor="#000000"
            app:tabIndicatorColor="#FFFFFF"
            app:tabTextColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" /> <!-- 가용 공간을 차지하도록 설정 -->
    </LinearLayout>
</LinearLayout>
