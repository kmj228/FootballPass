<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient2">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="게시판 등록하기"
            android:textColor="#C4C4C4"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="게시판 이름등록"
            android:id="@+id/busManager_boardTitle"
            android:textColor="#C4C4C4"
            android:textColorHint="#C4C4C4"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="게시판 설명등록"
            android:id="@+id/busManager_boardExplanation"
            android:textColor="#C4C4C4"
            android:textColorHint="#C4C4C4"
            />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/busManager_BoardEnterBtn"
            android:textColor="#C4C4C4"
            android:text="게시판 등록"
            />
    </LinearLayout>
</ScrollView>